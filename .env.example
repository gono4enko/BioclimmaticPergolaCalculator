# PostgreSQL — опционально (если не задан, цены берутся из data/price_tables/*.csv)
DATABASE_URL=postgresql://user:password@localhost:5432/bioclim_calc

# Обязательное — секрет Flask sessions, длинная случайная строка
SECRET_KEY=your_secret_key_here

# Обязательное — пароль для входа в админ-панель /admin
ADMIN_PASSWORD=change_me_strong_password

# Опционально — для AI-функций (генерация описаний и т.п.)
ANTHROPIC_API_KEY=your_key_here

# Email — куда уходят заявки от клиентов
EMAIL_TO=zakaz@infopergola.ru
SMTP_HOST=smtp.gmail.com
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password

# Telegram-уведомления о новых заявках (опционально, без токенов уведомления просто отключены)
TG_BOT_TOKEN=
TG_CHAT_ID=

# Порт (по умолчанию 5000)
PORT=5000
