# PostgreSQL — опционально (если не задан, цены берутся из data/price_tables/*.csv)
DATABASE_URL=postgresql://user:password@localhost:5432/bioclim_calc

# Обязательное — секрет Flask sessions, длинная случайная строка
SECRET_KEY=your_secret_key_here

# Обязательное — пароль для входа в админ-панель /admin
ADMIN_PASSWORD=change_me_strong_password

# Опционально — для AI-функций (генерация описаний и т.п.)
ANTHROPIC_API_KEY=your_key_here

# Gmail SMTP — куда уходят заявки клиентов с формы "Жду звонка" / Telegram / Max
# GMAIL_PASSWORD — это пароль приложения Google (16 символов без пробелов),
# создаётся в https://myaccount.google.com/apppasswords (требуется 2FA на аккаунте).
# Если все три не заданы — заявка всё равно сохранится в БД, но email не уйдёт.
GMAIL_USER=your@gmail.com
GMAIL_PASSWORD=your_16char_app_password
RECIPIENT_EMAIL=manager@example.com

# Twenty CRM / внутренний webhook — URL куда отправляется заявка при нажатии "Жду звонка".
# Заявка содержит: телефон, тип перголы, размеры, список опций, итоговую стоимость.
# Ошибка webhook НЕ блокирует email и сохранение в БД — отправка асинхронная.
# Если не задан или пустая строка — webhook отключён, email продолжает работать.
CRM_WEBHOOK_URL=https://erp.pergolarussia.ru/api/webhooks/calculator-lead

# Порт (по умолчанию 5000)
PORT=5000
