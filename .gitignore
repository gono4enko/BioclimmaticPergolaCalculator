data/calculations/*.json
data/cleanup_history.json

# .env файл с реальными секретами (на VPS production-сервере).
# В Replit секреты приходят через встроенный Secrets — .env не используется.
# .env.example остаётся в репозитории как шаблон.
.env
.env.local
.env.production

# ВАЖНО: CSV-файлы с прайсами в data/price_tables/ ДОЛЖНЫ быть в репозитории.
# При переносе на новый сервер они являются основным источником цен,
# а БД — только резервный. Не добавляйте сюда правил, исключающих *.csv
# из data/price_tables/, иначе сломается работа калькулятора без БД.
